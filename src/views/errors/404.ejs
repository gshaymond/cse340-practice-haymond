<%- include('../partials/header') %>
<main class="error-container error-404">
    <div class="error-content">
        <div class="error-image">
            <img src="/images/giphy.gif" alt="404 Not Found - Page not found animation">
        </div>
        
        <div class="error-info">
            <h1 class="error-title">404 - Page Not Found</h1>
            <p class="error-status">The page you're looking for doesn't exist.</p>
            
            <p class="error-description">
                It might have been moved, deleted, or the URL might be incorrect. 
                Let's get you back on track!
            </p>
            
            <div class="error-actions">
                <a href="/" class="btn btn-primary">Back to Homepage</a>
                <a href="/about" class="btn btn-secondary">About Us</a>
            </div>
            
            <div class="error-suggestions">
                <h3>Quick Links</h3>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/about">About</a></li>
                    <li><a href="/catalog">Course Catalog</a></li>
                </ul>
            </div>

            <% if (NODE_ENV === 'development') { %>
                <details class="error-details">
                    <summary>Debug Info (Development Only)</summary>
                    <div class="debug-info">
                        <p><strong>URL:</strong> <%= url %></p>
                        <p><strong>Timestamp:</strong> <%= timestamp %></p>
                        <p><strong>Status:</strong> <%= status %></p>
                    </div>
                </details>
            <% } %>
        </div>
    </div>
</main>
<%- include('../partials/footer') %>